---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{title}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;500;600;700&family=Noto+Sans+SC:wght@300;400;500&display=swap" rel="stylesheet">
<script defer src="https://cloud.umami.is/script.js" data-website-id="ec20b2fb-b2c3-47f3-bef0-d4eaf75870e6"></script>
</head>
<body>
<slot />

<div id="float-collapse" onclick="collapseFromFloat()">
<span class="arrow">&#x25B2;</span> <span class="zh">收起</span><span class="zht">收起</span><span class="en">Collapse</span>
</div>

<script is:inline>
function switchL1(t,el){
  document.getElementById('panel-mine').style.display=t==='mine'?'block':'none';
  document.getElementById('panel-guest').style.display=t==='guest'?'block':'none';
  document.querySelectorAll('.tab-l1').forEach(e=>e.classList.remove('active'));
  el.classList.add('active');
}
function switchL2(t,el){
  document.getElementById('panel-observe').style.display=t==='observe'?'block':'none';
  document.getElementById('panel-notes').style.display=t==='notes'?'block':'none';
  el.parentElement.querySelectorAll('.tab-l2').forEach(function(e){e.classList.remove('active')});
  el.classList.add('active');
}
function toggleSub(id,btn){
  var el=document.getElementById(id);
  var open=el.style.display==='block';
  el.style.display=open?'none':'block';
  btn.classList.toggle('open');
  btn.querySelector('.arrow').textContent=open?'\u25BC':'\u25B2';
  var zhSpan=btn.querySelector('.zh');
  var zhtSpan=btn.querySelector('.zht');
  var enSpan=btn.querySelector('.en');
  if(zhSpan)zhSpan.textContent=open?'展开':'收起';
  if(zhtSpan)zhtSpan.textContent=open?'展開':'收起';
  if(enSpan)enSpan.textContent=open?'Expand':'Collapse';
}
var _openFullId=null;
var _openFullBtn=null;
function toggleFull(id,btn){
  var el=document.getElementById(id);
  var open=el.style.display==='block';
  el.style.display=open?'none':'block';
  btn.classList.toggle('open');
  btn.querySelector('.arrow').textContent=open?'\u25BC':'\u25B2';
  var zhSpan=btn.querySelector('.zh');
  var zhtSpan=btn.querySelector('.zht');
  var enSpan=btn.querySelector('.en');
  if(zhSpan)zhSpan.textContent=open?'展开全文':'收起';
  if(zhtSpan)zhtSpan.textContent=open?'展開全文':'收起';
  if(enSpan)enSpan.textContent=open?'Read more':'Collapse';
  if(!open){_openFullId=id;_openFullBtn=btn;}
  else{_openFullId=null;_openFullBtn=null;}
  updateFloatBtn();
}
function updateFloatBtn(){
  var fb=document.getElementById('float-collapse');
  if(!fb)return;
  if(_openFullId){
    var el=document.getElementById(_openFullId);
    if(el&&el.style.display==='block'){fb.style.display='block';return;}
  }
  fb.style.display='none';
}
function collapseFromFloat(){
  if(!_openFullId||!_openFullBtn)return;
  var item=document.getElementById(_openFullId).closest('.item');
  toggleFull(_openFullId,_openFullBtn);
  if(item)item.scrollIntoView({behavior:'smooth',block:'start'});
}
function switchBookshelf(t,el){
  document.getElementById('panel-reading').style.display=t==='reading'?'block':'none';
  document.getElementById('panel-bookstores').style.display=t==='bookstores'?'block':'none';
  document.getElementById('bookshelf-tabs').querySelectorAll('.tab-l2').forEach(function(e){e.classList.remove('active')});
  el.classList.add('active');
}
function switchMedia(t,el){
  document.getElementById('panel-podcast').style.display=t==='podcast'?'block':'none';
  document.getElementById('panel-video').style.display=t==='video'?'block':'none';
  document.getElementById('media-tabs').querySelectorAll('.tab-l2').forEach(function(e){e.classList.remove('active')});
  el.classList.add('active');
}
function togglePlatforms(trigger){
  var popup=trigger.parentElement.querySelector('.platform-popup');
  var isOpen=popup.classList.contains('open');
  document.querySelectorAll('.platform-popup.open').forEach(function(p){p.classList.remove('open')});
  if(!isOpen)popup.classList.add('open');
}
document.addEventListener('click',function(e){
  if(!e.target.closest('.platform-select')){
    document.querySelectorAll('.platform-popup.open').forEach(function(p){p.classList.remove('open')});
  }
});
function setLang(lang){
  document.documentElement.lang=lang;
  document.getElementById('langZhCN').className=lang==='zh-CN'?'on':'off';
  document.getElementById('langZhTW').className=lang==='zh-TW'?'on':'off';
  document.getElementById('langEn').className=lang==='en'?'on':'off';
}
function toggleLang(){
  var cur=document.documentElement.lang;
  if(cur==='zh-CN')setLang('zh-TW');
  else if(cur==='zh-TW')setLang('en');
  else setLang('zh-CN');
}
</script>
</body>
</html>

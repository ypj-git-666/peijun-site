---
import books from '../data/books.json';
import bookstores from '../data/bookstores.json';

// Get unique cities in order of first appearance
const cities = [...new Map(bookstores.map(b => [b.city.en, b.city])).values()];
---

<div class="sec-divider"></div>

<section id="bookshelf">
<div class="sec-label"><span class="sec-num">05</span><span class="sec-title"><span class="zh">我的书架</span><span class="zht">我的書架</span><span class="en">My Bookshelf</span></span></div>

<div class="tabs-l2" id="bookshelf-tabs">
<div class="tab-l2 active" onclick="switchBookshelf('reading',this)"><span class="zh">书单</span><span class="zht">書單</span><span class="en">Reading List</span></div>
<div class="tab-l2" onclick="switchBookshelf('bookstores',this)"><span class="zh">书店</span><span class="zht">書店</span><span class="en">Bookstores</span></div>
</div>

<div id="panel-reading">
{books.map((book) => (
<div class="book-card">
<div class="book-left">
<div class="book-title"><span class="zh">{book.titleZh}</span><span class="zht">{book.titleTw}</span><span class="en">{book.titleEn}</span></div>
<div class="book-author">{book.author}</div>
<div class="book-oneliner"><span class="zh">{book.oneLinerZh}</span><span class="zht">{book.oneLinerTw}</span><span class="en">{book.oneLinerEn}</span></div>
</div>
<div class="book-right">
<div class="book-review"><span class="zh">{book.reviewZh}</span><span class="zht">{book.reviewTw}</span><span class="en">{book.reviewEn}</span></div>
</div>
</div>
))}
</div>

<div id="panel-bookstores" style="display:none;">
<div class="city-filters" id="city-filters">
{cities.map((city, index) => (
<button
  class={`city-btn ${index === 0 ? 'active' : ''}`}
  onclick={`filterBookstores('${city.en}',this)`}
  data-city-en={city.en}
>
  <span class="zh">{city.zh}</span><span class="zht">{city.tw}</span><span class="en">{city.en}</span>
</button>
))}
</div>

<div class="bookstores-grid" id="bookstores-grid">
{cities.map((city, cityIndex) => (
<div class="city-bookstores" data-city={city.en} style={cityIndex === 0 ? '' : 'display:none;'}>
  {bookstores.filter(b => b.city.en === city.en).map((store) => (
    <div class="bookstore-tag">
      {store.name}
      {store.closed && <span class="closed-badge"><span class="zh">已闭店</span><span class="zht">已閉店</span><span class="en">Closed</span></span>}
    </div>
  ))}
</div>
))}
</div>
</div>

</section>

<script is:inline>
function filterBookstores(cityEn, btn) {
  // Update active button
  document.querySelectorAll('.city-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');

  // Show/hide city bookstores
  document.querySelectorAll('.city-bookstores').forEach(div => {
    div.style.display = div.getAttribute('data-city') === cityEn ? 'flex' : 'none';
  });
}
</script>
